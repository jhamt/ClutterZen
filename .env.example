# AI Services
VISION_API_KEY=your_vision_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe API Keys
# NOTE: STRIPE_SECRET_KEY should be configured in backend/Firebase Functions env, not bundled in client app.
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Connect (optional)
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id_here

# Cloud Functions base URL (used for secure server-side API proxying)
FIREBASE_FUNCTIONS_URL=https://us-central1-clutterzen-test.cloudfunctions.net/api

# Google Sign-In server client ID (recommended for Android/iOS token exchange)
GOOGLE_SERVER_CLIENT_ID=

# Firebase web config (optional)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# App toggles
DISABLE_AUTH_GATE=false
