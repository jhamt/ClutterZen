rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }
    
    // Rate limiting helper (basic implementation)
    function rateLimit() {
      // Note: Full rate limiting requires Cloud Functions or App Check
      // This is a basic check - consider implementing App Check for production
      return true;
    }

    function safeUserCreate() {
      return (!('plan' in request.resource.data) ||
              request.resource.data.plan in ['free', 'Free'])
        && (!('scanCredits' in request.resource.data) ||
            (request.resource.data.scanCredits is int &&
             request.resource.data.scanCredits >= 0 &&
             request.resource.data.scanCredits <= 3))
        && !('creditsTotal' in request.resource.data)
        && !('creditsUsed' in request.resource.data)
        && !('stripeCustomerId' in request.resource.data)
        && !('stripeSubscriptionId' in request.resource.data)
        && !('subscriptionPlan' in request.resource.data)
        && !('subscriptionStatus' in request.resource.data)
        && !('stripePriceId' in request.resource.data);
    }

    function protectedUserFieldsUnchanged() {
      return request.resource.data.plan == resource.data.plan
        && request.resource.data.scanCredits == resource.data.scanCredits
        && request.resource.data.creditsTotal == resource.data.creditsTotal
        && request.resource.data.creditsUsed == resource.data.creditsUsed
        && request.resource.data.stripeCustomerId == resource.data.stripeCustomerId
        && request.resource.data.stripeSubscriptionId == resource.data.stripeSubscriptionId
        && request.resource.data.subscriptionPlan == resource.data.subscriptionPlan
        && request.resource.data.subscriptionStatus == resource.data.subscriptionStatus
        && request.resource.data.stripePriceId == resource.data.stripePriceId
        && request.resource.data.planUpdatedAt == resource.data.planUpdatedAt
        && request.resource.data.subscriptionStartedAt == resource.data.subscriptionStartedAt
        && request.resource.data.subscriptionCanceledAt == resource.data.subscriptionCanceledAt;
    }
    
    // Analyses collection
    match /analyses/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() 
        && request.resource.data.uid == request.auth.uid
        && rateLimit();
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.organizedImageUrl is string
        && (!('organizedRegensUsed' in request.resource.data) ||
            (request.resource.data.organizedRegensUsed is int &&
             request.resource.data.organizedRegensUsed >= 0 &&
             request.resource.data.organizedRegensUsed <= 5))
        && (!('organizedImageUpdatedAt' in request.resource.data) ||
             request.resource.data.organizedImageUpdatedAt is timestamp)
        && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly([
              'organizedImageUrl',
              'organizedRegensUsed',
              'organizedImageUpdatedAt',
            ]);
      allow delete: if false;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create: if signedIn()
        && userId == request.auth.uid
        && safeUserCreate();
      allow update: if signedIn()
        && userId == request.auth.uid
        && protectedUserFieldsUnchanged();
      allow delete: if false; // Prevent accidental deletion

      match /saved_plans/{planId} {
        allow read, create, update, delete: if signedIn()
          && userId == request.auth.uid;
      }
    }
    
    // Contact submissions
    match /contact_submissions/{submissionId} {
      allow create: if signedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 5000
        && rateLimit();
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Submissions are immutable
    }
    
    // Service bookings
    match /service_bookings/{bookingId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() 
        && request.resource.data.userId == request.auth.uid
        && rateLimit();
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.paymentIntentId == resource.data.paymentIntentId
        && request.resource.data.professionalAccountId == resource.data.professionalAccountId
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.currency == resource.data.currency
        && request.resource.data.applicationFee == resource.data.applicationFee
        && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['status', 'professionalName', 'hours', 'serviceDate', 'notes', 'confirmedAt']);
      allow delete: if false;
    }
    
    // Stripe connected accounts
    match /stripe_connected_accounts/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create, update, delete: if false; // Managed server-side only
    }

    // OAuth state docs used by backend callbacks only
    match /stripe_oauth_states/{stateId} {
      allow read, write: if false;
    }

    // Deny all other documents by default
    match /{document=**} {
      allow delete: if false;
      allow read, write: if false;
    }
  }
}


