# AI Services
VISION_API_KEY=your_vision_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here
# Nearby professionals (configure in Firebase Functions env for production)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
# Optional API quota guard caps (daily, server-side usage planning)
MAPS_DAILY_NEARBY_CAP=24
MAPS_DAILY_TEXT_CAP=8
MAPS_DAILY_DETAILS_CAP=28
MAPS_DAILY_GEOCODE_CAP=300
# Combined cap for premium Places calls (nearby + text + details)
MAPS_DAILY_PREMIUM_CAP=30
# Keep disabled to avoid Places Photo SKU spend unless explicitly needed
MAPS_ENABLE_PLACE_PHOTOS=false

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe API Keys
# NOTE: STRIPE_SECRET_KEY should be configured in backend/Firebase Functions env, not bundled in client app.
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Connect (optional)
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id_here

# Cloud Functions base URL (used for secure server-side API proxying)
FIREBASE_FUNCTIONS_URL=https://us-central1-clutterzen-test.cloudfunctions.net/api

# Google Sign-In server client ID (recommended for Android/iOS token exchange)
GOOGLE_SERVER_CLIENT_ID=

# Sign in with Apple (required for Android web-based Apple flow)
# Example:
# APPLE_SERVICE_ID=com.yourcompany.clutterzen.service
# APPLE_REDIRECT_URI=https://your-project-id.firebaseapp.com/__/auth/handler
APPLE_SERVICE_ID=
APPLE_REDIRECT_URI=

# Firebase web config (optional)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# App toggles
DISABLE_AUTH_GATE=false
