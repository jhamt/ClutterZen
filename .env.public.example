# Public client configuration only (safe to bundle)
FIREBASE_FUNCTIONS_URL=https://us-central1-your-project-id.cloudfunctions.net/api
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id_here
# Gemini should be configured in Firebase Functions env (recommended).
# Keep client key empty in production unless debug fallback is explicitly enabled.
GEMINI_API_KEY=
# Debug-only direct API fallback (disabled by default; keep false in production)
ALLOW_CLIENT_AI_FALLBACK=false
# Optional debug fallback keys (do not ship real secrets in production builds)
VISION_API_KEY=
REPLICATE_API_TOKEN=
GOOGLE_SERVER_CLIENT_ID=
DISABLE_AUTH_GATE=false
